# Copy this file to .env and fill in every value before running docker compose.
# .env is gitignored — never commit real secrets.

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.
AIRFLOW_WEBSERVER_PORT=8081

# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Random string used to sign Airflow internal JWTs (Airflow 2.9+)
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__API_AUTH__JWT_SECRET=

# Airflow web UI + REST API admin credentials
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=

# PostgreSQL metadata DB password
POSTGRES_PASSWORD=

# Airflow REST API credentials used by the agent (must match the admin user above)
AIRFLOW_API_BASE_URL=http://airflow-apiserver:8080
AIRFLOW_API_USERNAME=airflow
AIRFLOW_API_PASSWORD=

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_TRACES_SAMPLER=always_on
OTEL_PYTHON_LOG_CORRELATION=true

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set to "groq" (cloud) or "ollama" (local).  Default: ollama
LLM_PROVIDER=ollama

# Shared temperature applied to all providers (0.0 = deterministic)
LLM_TEMPERATURE=0.0

# Groq cloud LLM — only required when LLM_PROVIDER=groq
# Get a free API key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama local LLM — only required when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=512

# ── AI Agent Behaviour ────────────────────────────────────────────────────────
# Maximum ReAct loop iterations before the agent gives up
AGENT_MAX_ITERATIONS=20

# Maximum wall-clock seconds for a single agent invocation
AGENT_MAX_EXECUTION_TIME=180

# Seconds between event-loop poll cycles (credit-risk-agent Docker service)
AGENT_POLL_INTERVAL=60

# Set to "true" in headless/Docker service environments.
# When true, high-risk tool calls without Gmail configured are auto-rejected
# instead of silently bypassing the approval gate via a broken CLI prompt.
AGENT_NON_INTERACTIVE=false

# ── Pipeline Data Path ────────────────────────────────────────────────────────
# Absolute path inside the container where eligibility_programs.csv is written
ELIGIBILITY_CSV_PATH=/opt/airflow/data/processed/eligibility_programs.csv

# ── Gmail (Agent Approval Notifications) ─────────────────────────────────────
# Gmail address used to SEND approval requests and RECEIVE APPROVE/REJECT replies.
GMAIL_ADDRESS=you@gmail.com

# App Password — NOT your real Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=

GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993

# Seconds to wait for an APPROVE/REJECT email reply before auto-rejecting
APPROVAL_TIMEOUT_SECONDS=300
APPROVAL_POLL_INTERVAL=10

# SMTP settings (do not change these for Gmail)
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587

# IMAP settings (for reading your replies)
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993

# How long agent waits for your reply before auto-rejecting (seconds)
APPROVAL_TIMEOUT_SECONDS=300

# How often agent checks inbox for your reply (seconds)
APPROVAL_POLL_INTERVAL=10

# How often the autonomous agent polls Airflow for failures (seconds)
AIRFLOW_AGENT_POLL_INTERVAL=60

# Airflow API credentials (agent uses these to call the REST API)
AIRFLOW_API_BASE_URL=http://airflow-apiserver:8080
AIRFLOW_API_USERNAME=airflow
AIRFLOW_API_PASSWORD=change_me_local_only